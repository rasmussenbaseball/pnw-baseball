    "elev_pct_per_1000ft": 7.0,
    "elev_saturation_ft": 4000,
    "dim_pct_per_ft": 0.2,
    "temp_pct_per_deg_f": 0.45,
    "regression_games": 300,
    "recenter_shift": 2.07
  },
  "baseline_dimensions": "350 ft average outfield depth",
  "baseline_outfield_depth_ft": 350,
  "baseline_temperature_f": 60,
