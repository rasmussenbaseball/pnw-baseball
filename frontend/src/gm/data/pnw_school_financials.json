  "_meta": {
    "purpose": "Real-world tuition, room/board, and athletic budget data for every PNW school the GM game tracks. Used by newDynasty + newDynastyMultiLevel to seed accurate school financials.",
    "scope": "PNW programs only (per Nate's PNW-only direction). Numbers are 2024-25 published rates from school COA pages + EADA-disclosed athletic expense reports.",
    "tuitionNotes": "Public schools list out-of-state tuition because that's the realistic baseball-recruiting figure (most rosters have ~30-50% non-resident kids). Resident savings are reflected via the 'inStateDiscount' multiplier.",
    "budgetNotes": "Budgets are TOTAL annual baseball-program expense. Allocations split it across coaching/scholarships/travel/recruiting/equipment/facilities/operations. Real EADA breakdown is roughly: D1 P5 35% coaching / 30% schol / 10% travel / 5% recruiting / 5% equip / 8% facilities / 7% ops; mid-D1 + D2 redistribute lower scholarship dollars to coaching.",
    "lastUpdated": "2026-05-17"
  },

