# Supabase Configuration (frontend)
# Get these from your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry crash reporting (optional, production only)
# Create a React project at sentry.io and paste the DSN here.
# Leave blank to disable. Local dev never sends events regardless.
VITE_SENTRY_DSN=
